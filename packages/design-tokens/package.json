{
  "name": "@kommo-crm/design-tokens",
  "version": "0.1.0",
  "description": "Design tokens for Kommo CRM UI",
  "files": [
    "dist"
  ],
  "main": "./dist/tokens.cjs",
  "module": "./dist/tokens.mjs",
  "types": "./dist/tokens.d.ts",
  "exports": {
    ".": {
      "import": "./dist/tokens.mjs",
      "require": "./dist/tokens.cjs",
      "types": "./dist/tokens.d.ts"
    },
    "./css": "./dist/tokens.css",
    "./min.css": "./dist/tokens.min.css",
    "./less": "./dist/tokens.less",
    "./scss": "./dist/tokens.scss"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && ts-node -r tsconfig-paths/register --compiler-options '{\"module\":\"CommonJS\"}' src/index.ts",
    "dev": "nodemon --watch src --ext ts --exec \"ts-node -r tsconfig-paths/register --compiler-options '{\\\"module\\\":\\\"CommonJS\\\"}' src/index.ts\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "nodemon": "^3.1.9",
    "typescript": "5.5.4"
  }
}
