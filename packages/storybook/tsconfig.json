{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@ui-kit/*": ["../ui-kit/src/*"],
      "@ui-kit": ["../ui-kit/src/index"],
      "@storybook-utils/*": ["./storybook/*"],
      "@i18n": ["./.storybook/i18n.ts"],
      "@tokens/*": ["../tokens/dist/js/*"]
    }
  },
  "include": ["./**/*.tsx", "./**/*.ts", ".storybook/**/*", "../ui-kit/src/**/*.d.ts"],
  "exclude": ["node_modules", "storybook-static"]
}
