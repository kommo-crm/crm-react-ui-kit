{
  "name": "@kommo-crm/tokens",
  "version": "0.1.0",
  "description": "Design tokens for Kommo CRM UI",
  "files": [
    "dist"
  ],
  "exports": {
    "./light": {
      "types": "./dist/light/tokens.d.ts",
      "import": "./dist/light/tokens.mjs",
      "require": "./dist/light/tokens.cjs"
    },
    "./dark": {
      "types": "./dist/dark/tokens.d.ts",
      "import": "./dist/dark/tokens.mjs",
      "require": "./dist/dark/tokens.cjs"
    },
    "./light/css": "./dist/light/tokens.css",
    "./light/min.css": "./dist/light/tokens.min.css",
    "./light/less": "./dist/light/tokens.less",
    "./light/scss": "./dist/light/tokens.scss",
    "./light/json": "./dist/light/tokens.json",
    "./dark/css": "./dist/dark/tokens.css",
    "./dark/min.css": "./dist/dark/tokens.min.css",
    "./dark/less": "./dist/dark/tokens.less",
    "./dark/scss": "./dist/dark/tokens.scss",
    "./dark/json": "./dist/dark/tokens.json"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsx src/index.ts && tsup",
    "dev": "concurrently \"tsx watch src/index.ts\" \"tsup --watch --no-dts\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^9.1.2",
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "5.5.4"
  }
}
