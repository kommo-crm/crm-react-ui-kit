{
  "name": "@kommo-crm/tokens",
  "version": "1.0.0",
  "description": "Design tokens for Kommo CRM UI",
  "license": "SEE LICENSE IN LICENSE",
  "files": [
    "dist"
  ],
  "exports": {
    "./primitives": {
      "types": "./dist/primitives/tokens.d.ts",
      "import": "./dist/primitives/tokens.mjs",
      "require": "./dist/primitives/tokens.cjs"
    },
    "./primitives/css": "./dist/primitives/tokens.css",
    "./primitives/min.css": "./dist/primitives/tokens.min.css",
    "./primitives/scss": "./dist/primitives/tokens.scss",
    "./primitives/less": "./dist/primitives/tokens.less",
    "./primitives/json": "./dist/primitives/tokens.json",
    "./ui-kit/light": {
      "types": "./dist/light-ui-kit/tokens.d.ts",
      "import": "./dist/light-ui-kit/tokens.mjs",
      "require": "./dist/light-ui-kit/tokens.cjs"
    },
    "./ui-kit/light/css": "./dist/light-ui-kit/tokens.css",
    "./ui-kit/light/min.css": "./dist/light-ui-kit/tokens.min.css",
    "./ui-kit/light/less": "./dist/light-ui-kit/tokens.less",
    "./ui-kit/light/scss": "./dist/light-ui-kit/tokens.scss",
    "./ui-kit/light/json": "./dist/light-ui-kit/tokens.json",
    "./ui-kit/alternative": {
      "types": "./dist/alternative-ui-kit/tokens.d.ts",
      "import": "./dist/alternative-ui-kit/tokens.mjs",
      "require": "./dist/alternative-ui-kit/tokens.cjs"
    },
    "./ui-kit/alternative/css": "./dist/alternative-ui-kit/tokens.css",
    "./ui-kit/alternative/min.css": "./dist/alternative-ui-kit/tokens.min.css",
    "./ui-kit/alternative/less": "./dist/alternative-ui-kit/tokens.less",
    "./ui-kit/alternative/scss": "./dist/alternative-ui-kit/tokens.scss",
    "./ui-kit/alternative/json": "./dist/alternative-ui-kit/tokens.json",
    "./light": {
      "types": "./dist/light/tokens.d.ts",
      "import": "./dist/light/tokens.mjs",
      "require": "./dist/light/tokens.cjs"
    },
    "./light/css": "./dist/light/tokens.css",
    "./light/min.css": "./dist/light/tokens.min.css",
    "./light/scss": "./dist/light/tokens.scss",
    "./light/less": "./dist/light/tokens.less",
    "./light/json": "./dist/light/tokens.json",
    "./dark": {
      "types": "./dist/dark/tokens.d.ts",
      "import": "./dist/dark/tokens.mjs",
      "require": "./dist/dark/tokens.cjs"
    },
    "./dark/css": "./dist/dark/tokens.css",
    "./dark/min.css": "./dist/dark/tokens.min.css",
    "./dark/scss": "./dist/dark/tokens.scss",
    "./dark/less": "./dist/dark/tokens.less",
    "./dark/json": "./dist/dark/tokens.json"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsx src/index.ts && tsup",
    "dev": "concurrently \"tsx watch src/index.ts\" \"tsup --watch --no-dts\"",
    "test": "jest",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "20.0.0",
    "concurrently": "9.1.2",
    "jest": "30.3.0",
    "ts-jest": "29.4.6",
    "tsup": "8.3.0",
    "tsx": "4.19.2",
    "typescript": "5.5.4"
  }
}
