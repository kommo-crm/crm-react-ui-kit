{
  "name": "@kommo-crm/tokens",
  "version": "0.1.0",
  "description": "Design tokens for Kommo CRM UI",
  "files": [
    "dist"
  ],
  "main": "./dist/tokens.cjs",
  "module": "./dist/tokens.mjs",
  "types": "./dist/tokens.d.ts",
  "exports": {
    ".": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.mjs",
      "require": "./dist/tokens.cjs"
    },
    "./css": "./dist/tokens.css",
    "./min.css": "./dist/tokens.min.css",
    "./less": "./dist/tokens.less",
    "./scss": "./dist/tokens.scss"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsx src/index.ts && tsup",
    "dev": "concurrently \"tsx watch src/index.ts\" \"tsup --watch --no-dts\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^9.1.2",
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "5.5.4"
  }
}
