{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "@kommo-crm/crm-tokens#dev": {
      "dependsOn": [],
      "persistent": true,
      "cache": false
    },
    "@kommo-crm/storybook#dev": {
      "dependsOn": ["@kommo-crm/crm-tokens#build"],
      "persistent": true,
      "cache": false
    },
    "storybook": {
      "dependsOn": ["@kommo-crm/crm-tokens#build"],
      "persistent": true,
      "cache": false
    },
    "@kommo-crm/storybook#build-storybook": {
      "dependsOn": ["@kommo-crm/crm-tokens#build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "../ui-kit/src/**",
        "../ui-kit/stories/**",
        "../ui-kit/public/**"
      ],
      "outputs": ["storybook-static/**"]
    },
    "lint": {
      "cache": false
    },
    "lint:fix": {
      "cache": false
    },
    "test:e2e": {
      "cache": false
    },
    "test:e2e:update-snapshots": {
      "cache": false
    },
    "docker:clear-playwright-cache": {
      "cache": false
    }
  }
}
