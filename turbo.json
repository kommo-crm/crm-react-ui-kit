{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@kommo-crm/crm-react-ui-kit#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "cache": false
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "@kommo-crm/crm-tokens#dev": {
      "dependsOn": [],
      "persistent": true,
      "cache": false
    },
    "@kommo-crm/storybook#dev": {
      "dependsOn": [],
      "persistent": true,
      "cache": false
    },
    "storybook": {
      "persistent": true,
      "cache": false
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "cache": false,
      "inputs": [
        "$TURBO_DEFAULT$",
        ".storybook/**",
        "stories/**",
        "**/*.stories.*",
        "**/*.mdx",
        "tsconfig.json",
        "tsconfig.*.json",
        "vite.config.*",
        "webpack.config.*",
        ".env*"
      ],
      "outputs": ["storybook-static/**"]
    },
    "@kommo-crm/storybook#build-storybook": {
      "dependsOn": [],
      "cache": false,
      "outputs": ["storybook-static/**"]
    },
    "lint": {
      "cache": false
    }
  }
}
