{
  "name": "@kommo-crm/monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:ui-kit": "turbo run build --filter=@kommo-crm/crm-react-ui-kit",
    "build:tokens": "turbo run build --filter=@kommo-crm/crm-tokens",
    "build:storybook": "turbo run build-storybook --filter=@kommo-crm/storybook",
    "dev": "turbo run dev --filter=@kommo-crm/crm-tokens --filter=@kommo-crm/storybook",
    "dev:tokens": "turbo run dev --filter=@kommo-crm/crm-tokens",
    "storybook": "turbo run storybook --filter=@kommo-crm/storybook",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test:tokens": "turbo run test --filter=@kommo-crm/crm-tokens",
    "docker:clear-playwright-cache": "./packages/ui-kit/scripts/generate_env.docker.sh && docker compose --env-file=./.env.docker rm -f && docker volume rm crm-react-ui-kit_playwright_cache",
    "test:e2e": "./packages/ui-kit/scripts/generate_env.docker.sh && docker compose --env-file=./.env.docker up --abort-on-container-exit",
    "test:e2e:update-snapshots": "sh -c './packages/ui-kit/scripts/generate_env.docker.sh -u \"$@\" && docker compose --env-file=./.env.docker up --abort-on-container-exit' --",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "9.12.0",
    "@stylistic/eslint-plugin": "2.9.0",
    "@types/jest": "30.0.0",
    "concurrently": "9.1.2",
    "eslint": "9.12.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-import-resolver-typescript": "3.6.3",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsdoc": "50.3.1",
    "eslint-plugin-mdx": "3.1.5",
    "eslint-plugin-only-var": "0.1.2",
    "eslint-plugin-postcss-modules": "2.0.0",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-react": "7.37.1",
    "eslint-plugin-react-hooks": "4.6.2",
    "globals": "15.9.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "prettier": "3.4.2",
    "ts-jest": "29.4.6",
    "turbo": "2.8.17",
    "typescript": "5.5.4",
    "typescript-eslint": "8.2.0",
    "vite": "5.4.2",
    "vite-plugin-svgr": "4.2.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
