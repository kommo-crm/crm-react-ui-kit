{
  "name": "@kommo-crm/monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:ui-kit": "turbo run build --filter=@kommo-crm/crm-react-ui-kit",
    "build:design-tokens": "turbo run build --filter=@kommo-crm/design-tokens",
    "dev": "turbo run dev",
    "dev:ui-kit": "turbo run dev --filter=@kommo-crm/crm-react-ui-kit",
    "dev:design-tokens": "turbo run dev --filter=@kommo-crm/design-tokens",
    "storybook": "turbo run storybook --filter=@kommo-crm/crm-react-ui-kit",
    "build-storybook": "turbo run build-storybook --filter=@kommo-crm/crm-react-ui-kit",
    "lint": "turbo run lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "turbo": "2.8.17"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
