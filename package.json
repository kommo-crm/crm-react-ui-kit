{
  "name": "@kommo-crm/monorepo",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "storybook": "turbo run storybook --filter=@kommo-crm/crm-react-ui-kit-storybook",
    "build-storybook": "turbo run build-storybook --filter=@kommo-crm/crm-react-ui-kit-storybook",
    "docker:clear-playwright-cache": "cd packages/ui-kit && ./scripts/generate_env.docker.sh && docker compose --env-file=.env.docker rm -f && docker volume rm crm-react-ui-kit_playwright_cache",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e --filter=@kommo-crm/crm-react-ui-kit",
    "test:e2e:update-snapshots": "sh -c 'cd packages/ui-kit && ./scripts/generate_env.docker.sh -u \"$@\" && docker compose --env-file=.env.docker up --abort-on-container-exit' --",
    "test:e2e:ci": "turbo run test:e2e:ci --filter=@kommo-crm/crm-react-ui-kit",
    "eslint": "eslint --quiet",
    "tslint": "turbo run tslint",
    "lint": "turbo run lint",
    "lint:fix": "eslint --fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "9.12.0",
    "@playwright/experimental-ct-react": "1.47.0",
    "@playwright/test": "1.47.0",
    "@storybook/addon-essentials": "8.6.0",
    "@storybook/blocks": "8.6.0",
    "@storybook/react": "8.6.0",
    "@storybook/react-vite": "8.6.0",
    "@storybook/test": "8.6.0",
    "@stylistic/eslint-plugin": "2.9.0",
    "@swc/core": "1.7.28",
    "@swc/jest": "0.2.36",
    "@testing-library/jest-dom": "6.5.0",
    "@testing-library/react": "16.0.1",
    "@testing-library/user-event": "14.5.2",
    "@types/css": "0.0.38",
    "@types/glob": "8.1.0",
    "@types/hash-sum": "1.0.2",
    "@types/jest": "29.5.12",
    "@types/react": "18",
    "@types/react-dom": "18",
    "@vitejs/plugin-react": "4.3.1",
    "concurrently": "9.1.2",
    "css": "3.0.0",
    "eslint": "9.12.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-import-resolver-typescript": "3.6.3",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsdoc": "50.3.1",
    "eslint-plugin-mdx": "3.1.5",
    "eslint-plugin-only-var": "0.1.2",
    "eslint-plugin-postcss-modules": "2.0.0",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-react": "7.37.1",
    "eslint-plugin-react-hooks": "4.6.2",
    "globals": "15.9.0",
    "hash-sum": "2.0.0",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "jest-css-modules-transform": "4.4.2",
    "jest-environment-jsdom": "29.7.0",
    "jest-transformer-svg": "2.1.0",
    "postcss-color-function": "4.1.0",
    "postcss-import": "16.1.0",
    "postcss-nested": "6.2.0",
    "postcss-preset-env": "10.0.2",
    "postcss-selector-replace": "1.0.2",
    "prettier": "3.4.2",
    "prop-types": "15.8.1",
    "react": "18",
    "react-docgen-typescript": "2.2.2",
    "react-dom": "18",
    "storybook": "8.6.0",
    "ts-jest": "29.2.4",
    "ts-node": "10.9.2",
    "turbo": "2.5.6",
    "typescript": "5.5.4",
    "typescript-eslint": "8.2.0",
    "vite": "5.4.2",
    "vite-plugin-css-injected-by-js": "3.5.2",
    "vite-plugin-dts": "4.0.3",
    "vite-plugin-lib-inject-css": "2.1.1",
    "vite-plugin-svgr": "4.2.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
